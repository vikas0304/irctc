{
  "manifest_version": 3,
  "name": "IRCTC Intern Master (Test 4.1)",
  "version": "2",
  "permissions": ["activeTab", "debugger", "scripting", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.irctc.co.in/*"],
      "js": ["content.js"]
    }
  ]
}